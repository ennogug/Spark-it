# Environment Configuration for Spark'it
# Copy this file to .env and customize for your environment

# Server Port
PORT=3000

# Session Secret (generate a new random string for production)
SESSION_SECRET=your-secret-key-here-change-this-in-production

# Environment (development or production)
NODE_ENV=development

# Database Path (optional, defaults to ./database/images.db)
# DB_PATH=./database/images.db

# Uploads Directory (optional, defaults to ./uploads)
# UPLOADS_DIR=./uploads
